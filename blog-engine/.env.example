# ==========================================================================
# Lydell Security — Blog Engine — Environment Variables
# ==========================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ==========================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://lydell_admin:password@localhost:5432/lydell_blog

# ── AI Provider ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Unsplash ──────────────────────────────────────────────────────────────
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# ── Netlify ───────────────────────────────────────────────────────────────
NETLIFY_BUILD_HOOK=https://api.netlify.com/build_hooks/your-hook-id

# ── Observability (optional) ──────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO
ENVIRONMENT=development

# ── Content Defaults ─────────────────────────────────────────────────────
SITE_URL=https://lydellsecurity.com
SITE_NAME=Lydell Security
DEFAULT_AUTHOR=Larry Barksdale
INTERNAL_LINK_COUNT=4
